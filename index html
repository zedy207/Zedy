
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ø K A F É</title>
    <!-- Tailwind CSS for clean layout -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Space+Grotesk:wght@400;500&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #FBFBFB;
            -webkit-tap-highlight-color: transparent;
        }
        .heading-font {
            font-family: 'Space Grotesk', sans-serif;
        }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body x-data="cafeMenu()" class="text-neutral-900 antialiased">

    <!-- App Wrapper -->
    <div class="max-w-md mx-auto min-h-screen px-5 pt-8 pb-24 relative">
        
        <!-- Header -->
        <header class="w-full space-y-6">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="heading-font text-3xl font-medium tracking-tight">Ø K A F É</h1>
                    <p class="text-[11px] text-neutral-400 mt-0.5">Table 04 • Surat, Althan</p>
                </div>
                <div class="bg-neutral-100 px-3 py-1.5 rounded-full text-xs font-medium">
                    ✨ Minimal
                </div>
            </div>

            <!-- Categories -->
            <div class="flex gap-2 overflow-x-auto no-scrollbar py-1">
                <template x-for="cat in categories" :key="cat">
                    <button 
                        @click="activeCategory = cat"
                        :class="activeCategory === cat ? 'bg-neutral-950 text-white' : 'bg-white text-neutral-500 border border-neutral-200'"
                        class="px-5 py-2 rounded-full text-xs font-medium whitespace-nowrap transition-all duration-200"
                        x-text="cat">
                    </button>
                </template>
            </div>
        </header>

        <!-- Menu List -->
        <main class="mt-8 space-y-3">
            <template x-for="item in filteredItems()" :key="item.id">
                <div @click="openDetails(item)" 
                     class="bg-white rounded-xl border border-neutral-100 p-4 flex justify-between items-center cursor-pointer active:scale-[0.99] transition-transform shadow-xs">
                    <div class="space-y-1 max-w-[70%]">
                        <h3 class="heading-font font-medium text-neutral-900" x-text="item.name"></h3>
                        <p class="text-xs text-neutral-400 truncate" x-text="item.desc"></p>
                        <p class="heading-font text-sm font-medium text-neutral-950 mt-1" x-text="'$' + item.price.toFixed(2)"></p>
                    </div>
                    <div class="w-12 h-12 rounded-lg bg-neutral-50 flex items-center justify-center text-lg border border-neutral-100">
                        <span x-text="item.emoji"></span>
                    </div>
                </div>
            </template>
        </main>

        <!-- Dynamic Cart Toast -->
        <div class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[calc(100%-2.5rem)] max-w-sm bg-neutral-950 text-white rounded-full p-2 pl-5 flex justify-between items-center shadow-lg"
             x-show="cartCount > 0" style="display: none;">
            <span class="text-xs font-light" x-text="cartCount + ' item(s) selected'"></span>
            <button @click="cartCount = 0; alert('Order sent smoothly!')" class="bg-white text-neutral-950 px-4 py-2 rounded-full text-xs font-medium">
                Order Now →
            </button>
        </div>

        <!-- Detail Drawer -->
        <div x-show="isDrawerOpen" 
             class="fixed inset-0 bg-black/20 backdrop-blur-xs flex items-end justify-center z-50"
             style="display: none;"
             @click.self="isDrawerOpen = false">
            <div class="w-full max-w-md bg-white rounded-t-3xl p-6 space-y-4 shadow-xl">
                <div class="flex justify-between items-start">
                    <h2 class="heading-font text-xl font-medium" x-text="selectedItem.name"></h2>
                    <span class="heading-font font-medium" x-text="'$' + (selectedItem.price ? selectedItem.price.toFixed(2) : '')"></span>
                </div>
                <p class="text-xs text-neutral-500" x-text="selectedItem.desc"></p>
                <div class="pt-4 flex gap-2">
                    <button @click="isDrawerOpen = false" class="w-1/3 py-3 border border-neutral-200 rounded-xl text-xs text-neutral-400">Back</button>
                    <button @click="cartCount++; isDrawerOpen = false" class="flex-1 bg-neutral-950 text-white rounded-xl text-xs font-medium">Add to Cart</button>
                </div>
            </div>
        </div>

    </div>

    <script>
        function cafeMenu() {
            return {
                activeCategory: 'All',
                isDrawerOpen: false,
                selectedItem: {},
                cartCount: 0,
                categories: ['All', 'Brew', 'Eats', 'Matcha'],
                items: [
                    { id: 1, name: 'Cold Brew / Zero', category: 'Brew', price: 5.50, desc: 'Single-origin beans steeped cold for 24 hours.', emoji: '🥃' },
                    { id: 2, name: 'Ceremonial Matcha Latte', category: 'Matcha', price: 6.50, desc: 'Uji whisked matcha paired with premium oat milk.', emoji: '🍵' },
                    { id: 3, name: 'Espresso Tonic', category: 'Brew', price: 5.00, desc: 'Double shot espresso over sparkling tonic & citrus.', emoji: '🍋' },
                    { id: 4, name: 'Shokupan Avocado Toast', category: 'Eats', price: 11.00, desc: 'Japanese milk bread with avocado and chili oil.', emoji: '🍞' }
                ],
                filteredItems() {
                    if (this.activeCategory === 'All') return this.items;
                    return this.items.filter(i => i.category === this.activeCategory);
                },
                openDetails(item) {
                    this.selectedItem = item;
                    this.isDrawerOpen = true;
                }
            }
        }
    </script>
</body>
</html>
