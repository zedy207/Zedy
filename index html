<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ø K A F É — Minimalist Menu</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Alpine.js for smooth reactive state & animations -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <!-- Google Fonts: Space Grotesk & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #FBFBFB;
            -webkit-tap-highlight-color: transparent;
        }
        .heading-font {
            font-family: 'Space Grotesk', sans-serif;
        }
        /* Custom smooth scrollbar omission */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body x-data="cafeMenu()" class="text-neutral-900 select-none antialiased selection:bg-neutral-200">

    <!-- QR App Intro Loading Animation (Simulating scan trigger) -->
    <div x-init="setTimeout(() => loading = false, 1200)" x-show="loading" 
         class="fixed inset-0 z-50 bg-neutral-950 flex flex-col items-center justify-center text-white transition-all duration-700"
         x-transition:leave="opacity-0 scale-105 pointer-events-none">
        <div class="text-center space-y-3">
            <h2 class="heading-font text-3xl font-light tracking-widest uppercase animate-pulse">Ø K A F É</h2>
            <div class="h-[1px] w-12 bg-neutral-700 mx-auto"></div>
            <p class="text-[10px] uppercase tracking-widest text-neutral-400">Curating Vibrations</p>
        </div>
    </div>

    <!-- Main Application Shell -->
    <div class="max-w-md mx-auto min-h-screen flex flex-col justify-between relative px-5 pt-8 pb-24">
        
        <!-- Header Section -->
        <header class="w-full space-y-6">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="heading-font text-4xl font-medium tracking-tight text-neutral-950">Ø K A F É</h1>
                    <p class="text-xs text-neutral-400 mt-1 flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
                        Table 04 — Est. 2026
                    </p>
                </div>
                <button @click="activeVibe = activeVibe === 'cozy' ? 'cyber' : 'cozy'" 
                        class="border border-neutral-200 bg-white shadow-xs rounded-full p-2.5 text-xs font-medium hover:bg-neutral-50 active:scale-95 transition-all">
                    <span x-text="activeVibe === 'cozy' ? '⏳ Chill' : '⚡ Dynamic'"></span>
                </button>
            </div>

            <!-- Dynamic Horizontal Category Selection Bar -->
            <div class="flex gap-2 overflow-x-auto no-scrollbar py-1">
                <template x-for="cat in categories" :key="cat">
                    <button 
                        @click="activeCategory = cat"
                        :class="activeCategory === cat ? 'bg-neutral-950 text-white shadow-xs scale-102' : 'bg-white text-neutral-500 border border-neutral-200/70'"
                        class="px-5 py-2.5 rounded-full text-xs font-medium tracking-wide whitespace-nowrap transition-all duration-300 transform active:scale-95"
                        x-text="cat">
                    </button>
                </template>
            </div>
        </header>

        <!-- Menu Container -->
        <main class="mt-8 flex-1">
            <div class="space-y-4">
                <template x-for="(item, index) in filteredItems()" :key="item.id">
                    <!-- Smooth Minimal Card -->
                    <div 
                        @click="openDetails(item)"
                        class="bg-white rounded-2xl border border-neutral-100 p-4 flex justify-between items-center cursor-pointer shadow-xs hover:border-neutral-200 active:scale-[0.99] transition-all duration-200"
                        x-show="true"
                        x-transition:enter="transition ease-out duration-300"
                        x-transition:enter-start="opacity-0 translate-y-4"
                        x-transition:enter-end="opacity-100 translate-y-0">
                        
                        <div class="space-y-2 max-w-[70%]">
                            <div class="flex items-center gap-2">
                                <h3 class="heading-font font-medium text-neutral-900 tracking-tight" x-text="item.name"></h3>
                                <span x-show="item.tag" class="text-[9px] font-medium uppercase tracking-wider px-1.5 py-0.5 bg-neutral-100 text-neutral-600 rounded-sm" x-text="item.tag"></span>
                            </div>
                            <p class="text-xs text-neutral-400 line-clamp-1" x-text="item.desc"></p>
                            <p class="heading-font text-sm font-medium text-neutral-950" x-text="'$' + item.price.toFixed(2)"></p>
                        </div>

                        <!-- Minimal Visual Representation/Placeholder -->
                        <div class="w-16 h-16 rounded-xl bg-neutral-50 border border-neutral-100 flex items-center justify-center text-xl relative group">
                            <span x-text="item.emoji" class="group-hover:scale-110 transition-transform duration-300"></span>
                            <div class="absolute -bottom-1.5 -right-1.5 bg-neutral-950 text-white rounded-full w-5 h-5 flex items-center justify-center text-[10px] font-bold shadow-xs">
                                ＋
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </main>

        <!-- Fixed Bottom Status Bar / Cart Indicator -->
        <div class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[calc(100%-2.5rem)] max-w-sm bg-neutral-950 text-white rounded-full p-2.5 pl-6 flex justify-between items-center shadow-xl z-40"
             x-show="cartCount > 0"
             x-transition:enter="transition ease-out duration-300 transform translate-y-10 opacity-0"
             x-transition:enter-end="transform translate-y-0 opacity-100"
             x-transition:leave="transition ease-in duration-200 transform translate-y-10 opacity-0">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                <span class="text-xs tracking-wide font-light" x-text="cartCount + ' items selected'"></span>
            </div>
            <button @click="triggerOrder()" class="bg-white text-neutral-950 px-5 py-2 rounded-full text-xs font-medium uppercase tracking-wider hover:bg-neutral-100 active:scale-95 transition-all">
                Send to Bar →
            </button>
        </div>

        <!-- Sleek Bottom Drawers (Detail View Modal) -->
        <div x-show="isDrawerOpen" 
             class="fixed inset-0 z-50 bg-neutral-950/20 backdrop-blur-md flex items-end justify-center"
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             @click.self="isDrawerOpen = false">
            
            <div x-show="isDrawerOpen"
                 class="w-full max-w-md bg-white rounded-t-[2.5rem] p-8 shadow-2xl space-y-6"
                 x-transition:enter="transition ease-out duration-400 transform"
                 x-transition:enter-start="translate-y-full"
                 x-transition:enter-end="translate-y-0"
                 x-transition:leave="transition ease-in duration-300 transform"
                 x-transition:leave-start="translate-y-0"
                 x-transition:leave-end="translate-y-full">
                 
                 <!-- Micro Indicator Bar -->
                 <div class="w-12 h-1 bg-neutral-200 rounded-full mx-auto -mt-2"></div>
                 
                 <div class="flex justify-between items-start pt-2">
                     <div>
                         <span class="text-[10px] uppercase tracking-widest text-neutral-400 block mb-1" x-text="selectedItem.category"></span>
                         <h2 class="heading-font text-2xl font-medium text-neutral-950" x-text="selectedItem.name"></h2>
                     </div>
                     <span class="heading-font text-xl font-medium text-neutral-950" x-text="'$' + (selectedItem.price ? selectedItem.price.toFixed(2) : '')"></span>
                 </div>

                 <p class="text-xs text-neutral-500 leading-relaxed" x-text="selectedItem.desc"></p>

                 <!-- Interactivity customization options -->
                 <div class="space-y-3">
                     <span class="text-[10px] uppercase tracking-widest text-neutral-400 block">Select Brew Base</span>
                     <div class="grid grid-cols-2 gap-2">
                         <button class="border border-neutral-950 text-neutral-950 text-xs py-2.5 rounded-xl font-medium">Oat Milk</button>
                         <button class="border border-neutral-200 text-neutral-400 text-xs py-2.5 rounded-xl hover:border-neutral-300">Almond Milk</button>
                     </div>
                 </div>

                 <!-- Call to Action -->
                 <div class="pt-2 flex gap-3">
                     <button @click="isDrawerOpen = false" class="px-6 py-4 border border-neutral-200 rounded-2xl text-xs font-medium text-neutral-400 hover:text-neutral-600 transition-colors">Close</button>
                     <button @click="addToCart()" class="flex-1 bg-neutral-950 text-white rounded-2xl text-xs uppercase tracking-wider font-medium hover:bg-neutral-900 active:scale-98 transition-all flex justify-between items-center px-6 py-4">
                         <span>Add to Order</span>
                         <span x-text="selectedItem.emoji"></span>
                     </button>
                 </div>
            </div>
        </div>
    </div>

    <!-- Client-side Encapsulated Controller Script (Clean & Safe Architecture) -->
    <script>
        function cafeMenu() {
            return {
                loading: true,
                activeCategory: 'All',
                activeVibe: 'cozy',
                isDrawerOpen: false,
                selectedItem: {},
                cartCount: 0,
                categories: ['All', 'Brew', 'Eats', 'Matcha', 'Cold'],
                items: [
                    { id: 1, name: 'Cold Brew / Zero', category: 'Cold', price: 5.50, desc: 'Single-origin beans steeped cold for 24 hours over custom rock ice.', emoji: '🥃', tag: 'Signature' },
                    { id: 2, name: 'Ceremonial Matcha Latte', category: 'Matcha', price: 6.50, desc: 'Uji whisked matcha paired smoothly with texturized oat emulsion.', emoji: '🍵', tag: 'Popular' },
                    { id: 3, name: 'Espresso Tonic', category: 'Brew', price: 5.00, desc: 'Double shot espresso floating effortlessly over sparkling tonic & citrus essence.', emoji: '🍋', tag: null },
                    { id: 4, name: 'Shokupan Avocado Toast', category: 'Eats', price: 11.00, desc: 'Thick-cut Japanese milk bread with perfectly whipped hass avocado, chili oil crystals.', emoji: '🍞', tag: 'Fresh' },
                    { id: 5, name: 'Cardamom Flat White', category: 'Brew', price: 4.75, desc: 'Micro-foamed milk combined cleanly with organic crushed cardamom seed.', emoji: '☕', tag: null }
                ],
                filteredItems() {
                    if (this.activeCategory === 'All') return this.items;
                    return this.items.filter(i => i.category === this.activeCategory);
                },
                openDetails(item) {
                    this.selectedItem = item;
                    this.isDrawerOpen = true;
                },
                addToCart() {
                    this.cartCount++;
                    this.isDrawerOpen = false;
                },
                triggerOrder() {
                    alert('✨ Code Execution: Clean request token compiled and emitted securely via simulated WebSocket! Bar is prepping your order.');
                    this.cartCount = 0;
                }
            }
        }
    </script>
</body>
</html>
